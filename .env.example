APP_ENV=dev
PAPER_TRADING=true              # must be true, otherwise the app refuses to start
LLM_PROVIDER=groq               # groq | gemini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Futures testnet (agents must be able to SHORT -> spot is not enough).
# Binance Futures is geo-blocked in France; use Kraken Futures demo (krakenfutures)
# or MEXC. Kraken Futures perpetual symbols look like BTC/USD:USD.
EXCHANGE_ID=krakenfutures       # krakenfutures (demo) | mexc
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_SANDBOX=true           # must be true
# Offline/demo default uses .../USDT symbols (mock prices). For a live Kraken
# Futures testnet, set e.g. ASSET_WHITELIST=BTC/USD:USD,ETH/USD:USD,SOL/USD:USD
ASSET_WHITELIST=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT
CONFIDENCE_THRESHOLD=0.6
SLACK_WEBHOOK_URL=
WEBHOOK_SECRET=change-me
REDIS_URL=redis://localhost:6379/0
RSS_FEEDS=
RSS_POLL_INTERVAL_S=30
