APP_ENV=dev
PAPER_TRADING=true              # must be true, otherwise the app refuses to start
LLM_PROVIDER=groq               # groq | gemini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
EXCHANGE_ID=binance             # binance (spot testnet) or bybit (testnet)
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_SANDBOX=true           # must be true
ASSET_WHITELIST=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT
CONFIDENCE_THRESHOLD=0.6
SLACK_WEBHOOK_URL=
WEBHOOK_SECRET=change-me
REDIS_URL=redis://localhost:6379/0
RSS_FEEDS=
RSS_POLL_INTERVAL_S=30
