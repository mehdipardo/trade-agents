APP_ENV=dev
PAPER_TRADING=true              # must be true, otherwise the app refuses to start
# ============================================================================
# ONLY REQUIRED STEP TO GO LIVE: paste a free Groq key below. Everything else
# already works out of the box (news firehose + economic calendar are pre-wired).
# Without a key the app still runs on a deterministic offline classifier.
# ============================================================================
LLM_PROVIDER=groq               # groq | gemini
GROQ_API_KEY=                   # <-- paste your free Groq API key here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Futures testnet (agents must be able to SHORT -> spot is not enough).
# MEXC is the default: it covers crypto AND TradFi perpetuals (stocks, indices,
# commodities) — one venue for the whole whitelist. Kraken Futures works too
# but only for the crypto subset (its perpetuals look like BTC/USD:USD).
EXCHANGE_ID=mexc                # mexc | krakenfutures (crypto only)
EXCHANGE_API_KEY=
EXCHANGE_SECRET=
EXCHANGE_SANDBOX=true           # must be true
# Mixed crypto + TradFi whitelist. Trim it if you want to restrict the universe.
ASSET_WHITELIST=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,DOGE/USDT,GOLD/USDT,SILVER/USDT,OIL/USDT,SPX/USDT,BABA/USDT,TSLA/USDT,NVDA/USDT,AVGO/USDT,AAPL/USDT,MSFT/USDT,META/USDT
CONFIDENCE_THRESHOLD=0.6
# Freshness gate: drop wild-feed news older than this many seconds (already
# priced in / re-syndicated). 0 disables. Default 6h. Manual injects are exempt.
MAX_NEWS_AGE_S=21600
SLACK_WEBHOOK_URL=
WEBHOOK_SECRET=change-me
REDIS_URL=redis://localhost:6379/0
# --- LLM observability (optional): Langfuse tracing -------------------------
# Self-host with deploy/langfuse/docker-compose.yml, create a project, paste its
# keys here. Every analyst + critique LLM call is then traced (prompt, response,
# latency, tokens) and replayable. Inert while empty.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
RSS_FEEDS=
RSS_POLL_INTERVAL_S=30
# --- Live sources (pre-wired, free, no key needed) --------------------------
# Broad real-time news firehose (200+ outlets via SSE) — the primary source:
AGGREGATOR_SSE_URL=https://cryptocurrency.cv/api/sse
# Economic calendar (free Forex Factory feed) — armed events fire near release:
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
# Trump / Truth Social — Mastodon-shaped public statuses feed (or a mirror):
TRUTH_SOCIAL_URL=           # e.g. https://truthsocial.com/api/v1/accounts/<id>/statuses
TRUTH_SOCIAL_POLL_INTERVAL_S=10
# US Congress bill tracker (free API key from api.congress.gov):
CONGRESS_API_KEY=
CONGRESS_TRACKED_BILLS=      # e.g. 119/hr/1747,119/s/1582  (CLARITY, GENIUS…)
CONGRESS_POLL_INTERVAL_S=300
